# Renomme ce fichier en .env.local et remplis tes vraies cles.
# NE LE COMMIT JAMAIS SUR GIT. Ne le partage avec personne.

# ----- Apify (etape 2 du guide — candidat principal) -----
# Token API personnel Apify (commence par "apify_api_")
APIFY_TOKEN=

# Identifiant de l'actor Instagram (avec ~ a la place du /)
# Exemple : apify~instagram-scraper
APIFY_INSTAGRAM_ACTOR=

# Identifiant de l'actor TikTok
# Exemple : clockworks~tiktok-scraper
APIFY_TIKTOK_ACTOR=

# ----- RapidAPI (etape 3 du guide — backup) -----
# Cle unique a ton compte RapidAPI, recuperee sur ton dashboard
RAPIDAPI_KEY=

# Hote (host) de l'API Instagram a laquelle tu t'es abonne
# Exemple : instagram-scraper-api2.p.rapidapi.com
RAPIDAPI_INSTAGRAM_HOST=

# Chemin de l'endpoint Instagram (apres l'hote)
# Exemple typique : /v1/post_info?code_or_id_or_url=
# Le script ajoute l'URL encodee a la fin.
RAPIDAPI_INSTAGRAM_PATH=

# Hote de l'API TikTok
# Exemple : tiktok-scraper7.p.rapidapi.com
RAPIDAPI_TIKTOK_HOST=

# Chemin de l'endpoint TikTok (apres l'hote)
# Exemple : /?url=
RAPIDAPI_TIKTOK_PATH=
