# =============================================================================
# Variables d'environnement du Worker
# =============================================================================
# Copier vers .env.local (dev) ou définir sur Railway (prod)
# =============================================================================

# ---- Supabase ---------------------------------------------------------------
SUPABASE_URL=https://YOUR-PROJECT.supabase.co
SUPABASE_SERVICE_ROLE_KEY=ey...                # ⚠️ secret, jamais exposer côté app
SUPABASE_STORAGE_BUCKET=recipe-media

# ---- OpenAI (Whisper) -------------------------------------------------------
OPENAI_API_KEY=sk-...
OPENAI_WHISPER_MODEL=whisper-1

# ---- Anthropic (Claude vision + fusion) ------------------------------------
ANTHROPIC_API_KEY=sk-ant-...
ANTHROPIC_MODEL_VISION=claude-haiku-4-5
ANTHROPIC_MODEL_FUSION=claude-sonnet-4-6

# ---- API tierce (scraping Insta/TikTok) ------------------------------------
# Provider retenu V1.0 = scrapecreators (tâche zéro du 13/05/2026).
# Stub renvoie une recette factice — utile pour debug pipeline aval sans appel externe.
SOCIAL_API_PROVIDER=scrapecreators            # stub | rapidapi | apify | scrapecreators
SCRAPECREATORS_API_KEY=                       # clé récupérée sur https://app.scrapecreators.com
# Legacy / réservé pour fallback futur
SOCIAL_API_KEY=
SOCIAL_API_BASE_URL=

# ---- Worker --------------------------------------------------------------
WORKER_CONCURRENCY=2                          # nb de jobs en parallèle max
WORKER_MAX_DURATION_SECONDS=180               # timeout d'un job complet
WORKER_MAX_VIDEO_SECONDS=300                  # 5 min, au-delà → failed
WORKER_FRAMES_PER_VIDEO=8                     # frames extraites pour Claude vision

# ---- Logs / debug -----------------------------------------------------------
LOG_LEVEL=info                                # debug | info | warn | error
